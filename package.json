{
  "name": "ogbeni-eat-backend",
  "version": "0.1.0",
  "description": "Backend for the Ogbeni Eats food vendor platform",
  "main": "app.ts",
  "scripts": {
    "start": "tsx app.ts",
    "dev": "tsx watch app.ts",
    "build": "tsc --noEmit",
    "test": "jest --config jest.config.js --forceExit --detectOpenHandles",
    "test:coverage": "jest --forceExit --detectOpenHandles --coverage",
    "seed": "tsx scripts/seed_db.ts",
    "seed:admin": "tsx scripts/seed_admin.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@types/bcryptjs": "^2.4.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.30",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
